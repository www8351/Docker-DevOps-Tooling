{
  "title": "Stack Containers",
  "uid": "stack-containers",
  "schemaVersion": 39,
  "editable": false,
  "timezone": "browser",
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "CPU usage per container",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"compose-.*\"}[2m]))",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Memory working set per container",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{name=~\"compose-.*\"}",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Network received per container",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_network_receive_bytes_total{name=~\"compose-.*\"}[2m]))",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "nginx active connections",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "nginx_connections_active",
          "legendFormat": "active"
        }
      ]
    }
  ]
}
