# Copy to .env and adjust. Compose reads .env automatically.
# No secrets here — ports and image tags only.

# Host ports
NGINX_PORT=8080
HTTPD_PORT=8081
PORTAINER_PORT=9000

# Observability profile (docker compose --profile observability up)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin

# Image tags — pinned by default.
# The alpine variants are load-bearing: their busybox `wget` powers the
# compose healthchecks, so keep alpine-based tags when bumping versions.
NGINX_TAG=1.27-alpine
HTTPD_TAG=2.4-alpine
PORTAINER_TAG=2.27.9
PROMETHEUS_TAG=v3.13.0
GRAFANA_TAG=12.3.8
CADVISOR_TAG=v0.55.1
NGINX_EXPORTER_TAG=1.5.1
